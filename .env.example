# Environment
NODE_ENV=development
PORT=4200

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sigops_dev

# Redis
REDIS_URL=redis://localhost:6379

# Auth / JWT
JWT_SECRET=change-me-shared-secret-minimum-32-characters-long
